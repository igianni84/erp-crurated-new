###############################################################################
# Crurated ERP - Staging Environment Configuration
###############################################################################
# Copy this file to .env on the staging server and fill in the values.
# Site: cruratedstaging.giovannibroegg.it
###############################################################################

APP_NAME="Crurated ERP (Staging)"
APP_ENV=staging
APP_KEY=                         # Generated with: php artisan key:generate
APP_DEBUG=false
APP_URL=https://cruratedstaging.giovannibroegg.it

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

#------------------------------------------------------------------------------
# Logging
#------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

#------------------------------------------------------------------------------
# Database (MySQL on Ploi server)
#------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erpcrurated_staging
DB_USERNAME=erpcrurated_staging
DB_PASSWORD=                     # Set via Ploi environment variables

#------------------------------------------------------------------------------
# Session
#------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=cruratedstaging.giovannibroegg.it
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

#------------------------------------------------------------------------------
# Cache & Queue
#------------------------------------------------------------------------------
CACHE_STORE=database
CACHE_PREFIX=crurated_erp_staging

QUEUE_CONNECTION=database

#------------------------------------------------------------------------------
# Redis (optional — database driver is fine for staging)
#------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

#------------------------------------------------------------------------------
# Broadcast & Filesystem
#------------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

#------------------------------------------------------------------------------
# Mail (use log or configure SMTP for staging email testing)
#------------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply-staging@crurated.com"
MAIL_FROM_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# Vite / Frontend
#------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# Stripe (use test mode keys for staging)
#------------------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300

#------------------------------------------------------------------------------
# Xero (optional for staging)
#------------------------------------------------------------------------------
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_TENANT_ID=
XERO_REDIRECT_URI=https://cruratedstaging.giovannibroegg.it/admin/xero/callback
XERO_SYNC_ENABLED=false
XERO_MAX_RETRY_COUNT=3

#------------------------------------------------------------------------------
# Liv-ex (optional for staging)
#------------------------------------------------------------------------------
LIVEX_API_URL=https://api.liv-ex.com
LIVEX_API_KEY=
LIVEX_CACHE_SEARCH_TTL=3600
LIVEX_CACHE_DETAIL_TTL=86400

#------------------------------------------------------------------------------
# Error Monitoring
#------------------------------------------------------------------------------
SENTRY_LARAVEL_DSN=

#------------------------------------------------------------------------------
# AI Assistant
#------------------------------------------------------------------------------
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic
AI_ASSISTANT_MODEL=claude-sonnet-4-5-20250929
AI_ASSISTANT_MAX_STEPS=10
AI_ASSISTANT_TEMPERATURE=0.3
AI_RATE_LIMIT_PER_HOUR=60
AI_RATE_LIMIT_PER_DAY=500

#------------------------------------------------------------------------------
# Finance Module
#------------------------------------------------------------------------------
FINANCE_SUBSCRIPTION_OVERDUE_DAYS=14
FINANCE_STORAGE_OVERDUE_DAYS=30
FINANCE_IMMEDIATE_INVOICE_ALERT_HOURS=24
FINANCE_BASE_CURRENCY=EUR
FINANCE_SELLER_COUNTRY=IT
FINANCE_VALIDATE_PRICING=false
FINANCE_DEFAULT_VAT_RATE=22.00
FINANCE_STORAGE_BILLING_CYCLE=monthly
FINANCE_STORAGE_DEFAULT_RATE=0.0050
FINANCE_STORAGE_MINIMUM_CHARGE=5.00
FINANCE_STORAGE_BILLING_TIME=05:00
FINANCE_STORAGE_AUTO_ISSUE=true
FINANCE_STRIPE_LOG_RETENTION_DAYS=90
FINANCE_XERO_LOG_RETENTION_DAYS=90
FINANCE_LOG_CLEANUP_TIME=03:00

#------------------------------------------------------------------------------
# Commercial Module (EMP)
#------------------------------------------------------------------------------
EMP_DEVIATION_THRESHOLD=15.0
EMP_STALE_THRESHOLD_DAYS=7

#------------------------------------------------------------------------------
# Audit
#------------------------------------------------------------------------------
AUDIT_RETENTION_DAYS=365
AUDIT_AI_RETENTION_DAYS=180
AUDIT_ARCHIVAL_TIME=03:30
AUDIT_ARCHIVAL_BATCH_SIZE=5000
