###############################################################################
# Crurated ERP - Production Environment Configuration
###############################################################################
# Copy to .env on production server. All values below are production-ready
# defaults or placeholders that MUST be filled in before deployment.
###############################################################################

#------------------------------------------------------------------------------
# Application Settings
#------------------------------------------------------------------------------
APP_NAME="Crurated ERP"
APP_ENV=production
APP_KEY=                             # php artisan key:generate
APP_DEBUG=false                      # NEVER true in production
APP_URL=https://crurated.giovannibroegg.it

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=14                     # Higher = more secure (12-14 recommended for prod)

#------------------------------------------------------------------------------
# Logging
#------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily,slack                # daily for files + slack for critical alerts
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                    # warning | error (not debug in prod)
LOG_DAILY_DAYS=14
LOG_SLACK_WEBHOOK_URL=               # REQUIRED for slack channel
LOG_SLACK_USERNAME="Crurated ERP"
LOG_SLACK_EMOJI=:warning:

#------------------------------------------------------------------------------
# Database (MySQL)
#------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erpcrurated
DB_USERNAME=                         # REQUIRED
DB_PASSWORD=                         # REQUIRED — use strong password

#------------------------------------------------------------------------------
# Session (Redis-backed)
#------------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=crurated.giovannibroegg.it
SESSION_SECURE_COOKIE=true           # HTTPS only
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

#------------------------------------------------------------------------------
# Cache (Redis)
#------------------------------------------------------------------------------
CACHE_STORE=redis
CACHE_PREFIX=crurated_erp

#------------------------------------------------------------------------------
# Queue (Redis + Horizon)
#------------------------------------------------------------------------------
QUEUE_CONNECTION=redis               # Required for Horizon

#------------------------------------------------------------------------------
# Redis
#------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                      # REQUIRED — set a strong password
REDIS_PORT=6379

#------------------------------------------------------------------------------
# Laravel Horizon
#------------------------------------------------------------------------------
HORIZON_PREFIX=crurated_erp_horizon:

#------------------------------------------------------------------------------
# Broadcast / Filesystem / Mail
#------------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=smtp                     # Configure for production email provider
MAIL_SCHEME=null
MAIL_HOST=                           # REQUIRED
MAIL_PORT=587                        # TLS
MAIL_USERNAME=                       # REQUIRED
MAIL_PASSWORD=                       # REQUIRED
MAIL_FROM_ADDRESS="noreply@crurated.com"
MAIL_FROM_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# Stripe (Payment Processing)
#------------------------------------------------------------------------------
STRIPE_KEY=                          # pk_live_*
STRIPE_SECRET=                       # sk_live_*
STRIPE_WEBHOOK_SECRET=               # whsec_*
STRIPE_WEBHOOK_TOLERANCE=300

#------------------------------------------------------------------------------
# Xero (Accounting)
#------------------------------------------------------------------------------
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_TENANT_ID=
XERO_REDIRECT_URI=
XERO_SYNC_ENABLED=true
XERO_MAX_RETRY_COUNT=3
XERO_ACCOUNT_CODE_INV0=200
XERO_ACCOUNT_CODE_INV1=210
XERO_ACCOUNT_CODE_INV2=220
XERO_ACCOUNT_CODE_INV3=230
XERO_ACCOUNT_CODE_INV4=240

#------------------------------------------------------------------------------
# Liv-ex (Wine Data)
#------------------------------------------------------------------------------
LIVEX_API_URL=https://api.liv-ex.com
LIVEX_API_KEY=
LIVEX_CACHE_SEARCH_TTL=3600
LIVEX_CACHE_DETAIL_TTL=86400

#------------------------------------------------------------------------------
# Error Monitoring
#------------------------------------------------------------------------------
SENTRY_LARAVEL_DSN=                  # REQUIRED for production error tracking

#------------------------------------------------------------------------------
# AI Assistant
#------------------------------------------------------------------------------
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic
AI_ASSISTANT_MODEL=claude-sonnet-4-5-20250929
AI_ASSISTANT_MAX_STEPS=10
AI_ASSISTANT_TEMPERATURE=0.3
AI_ASSISTANT_MAX_INPUT_LENGTH=2000
AI_ASSISTANT_MAX_CONTEXT_MESSAGES=30
AI_RATE_LIMIT_PER_HOUR=60
AI_RATE_LIMIT_PER_DAY=500

#------------------------------------------------------------------------------
# Finance Module
#------------------------------------------------------------------------------
FINANCE_SUBSCRIPTION_OVERDUE_DAYS=14
FINANCE_STORAGE_OVERDUE_DAYS=30
FINANCE_IMMEDIATE_INVOICE_ALERT_HOURS=24
FINANCE_BASE_CURRENCY=EUR
FINANCE_SELLER_COUNTRY=IT
FINANCE_VALIDATE_PRICING=true        # Enable pricing validation in prod
FINANCE_DEFAULT_VAT_RATE=22.00
FINANCE_ENABLE_REVERSE_CHARGE=false
FINANCE_REQUIRE_VAT_NUMBER=true
FINANCE_STORAGE_BILLING_CYCLE=monthly
FINANCE_STORAGE_DEFAULT_RATE=0.0050
FINANCE_STORAGE_MINIMUM_CHARGE=5.00
FINANCE_STORAGE_BILLING_TIME=05:00
FINANCE_STORAGE_AUTO_ISSUE=true
FINANCE_DEFAULT_SHIPPING_VAT=22.00
FINANCE_ENABLE_DUTY_CALCULATION=true
FINANCE_DE_MINIMIS_EUR=150.00
FINANCE_STRIPE_LOG_RETENTION_DAYS=90
FINANCE_XERO_LOG_RETENTION_DAYS=90
FINANCE_LOG_CLEANUP_TIME=03:00

#------------------------------------------------------------------------------
# Commercial Module (EMP)
#------------------------------------------------------------------------------
EMP_DEVIATION_THRESHOLD=15.0
EMP_STALE_THRESHOLD_DAYS=7

#------------------------------------------------------------------------------
# Audit Log Archival
#------------------------------------------------------------------------------
AUDIT_RETENTION_DAYS=365
AUDIT_AI_RETENTION_DAYS=180
AUDIT_ARCHIVAL_TIME=03:30
AUDIT_ARCHIVAL_BATCH_SIZE=5000
